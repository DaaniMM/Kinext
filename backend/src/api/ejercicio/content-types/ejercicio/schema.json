{
  "kind": "collectionType",
  "collectionName": "ejercicios",
  "info": {
    "singularName": "ejercicio",
    "pluralName": "ejercicios",
    "displayName": "Ejercicios"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "nombre": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "descripcion": {
      "type": "richtext",
      "required": true
    },
    "musculo_trabajado": {
      "type": "customField",
      "customField": "plugin::multi-select.multi-select",
      "default": "[]",
      "options": [
        "Pecho",
        "Espalda",
        "Hombros",
        "Bíceps",
        "Tríceps",
        "Cuádriceps",
        "Isquiotibiales",
        "Glúteos",
        "Abdominales",
        "Core",
        "Pantorrillas"
      ],
      "required": true,
      "min": 1,
      "max": 8
    },
    "categoria": {
      "type": "customField",
      "customField": "plugin::multi-select.multi-select",
      "default": "[]",
      "options": [
        "Fuerza",
        "Hipertrofia",
        "Funcional",
        "Movilidad",
        "Cardio",
        "Rehabilitación",
        "Calentamiento",
        "Estiramiento"
      ],
      "required": true,
      "min": 1,
      "max": 3
    },
    "deficultad": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "Principiante",
        "Intermedio",
        "Avanzado"
      ]
    },
    "video_demo": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "files",
        "videos"
      ]
    },
    "analises": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::analisis.analisis",
      "mappedBy": "ejercicio"
    },
    "entreno_series": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::entreno-serie.entreno-serie",
      "mappedBy": "ejercicio"
    }
  }
}
