      "required": true,
      "unique": false
    },
    "asunto": {
      "type": "string",
      "required": true
    },
    "mensaje": {
      "type": "text",
      "required": true
    },
    "leido": {
      "type": "boolean",
      "required": true,
      "default": false
    }
  }
}
