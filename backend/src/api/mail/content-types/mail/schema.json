{
  "kind": "collectionType",
  "collectionName": "mails",
  "info": {
    "singularName": "mail",
    "pluralName": "mails",
    "displayName": "Mails"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
