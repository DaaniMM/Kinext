{
  "kind": "collectionType",
  "collectionName": "articulos",
  "info": {
    "singularName": "articulo",
    "pluralName": "articulos",
    "displayName": "Articulos"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "titulo": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "uid",
      "targetField": "titulo",
      "required": true
    },
    "contenido": {
      "type": "richtext",
      "required": true
    },
    "categoria": {
      "type": "customField",
      "customField": "plugin::multi-select.multi-select",
      "default": "[]",
      "options": [
        "Biomecánica",
        "Nutrición",
        "Entrenamiento",
        "Técnica",
        "Motivación",
        "Salud"
      ],
      "required": true,
      "min": 1,
      "max": 6
    },
    "imagen_portada": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "extracto": {
      "type": "text",
      "required": true
    },
    "autor": {
      "type": "string",
      "required": true
    }
  }
}
