{
  "kind": "collectionType",
  "collectionName": "analises",
  "info": {
    "singularName": "analisis",
    "pluralName": "analises",
    "displayName": "Analisis"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "ejercicio": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::ejercicio.ejercicio",
      "inversedBy": "analises"
    },
    "usuario": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::usuario.usuario",
      "inversedBy": "analises"
    },
    "video_usuario": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "files",
        "videos"
      ]
    },
    "resultado_ia": {
      "type": "text",
      "required": true
    },
    "puntuacion": {
      "type": "decimal",
      "required": true,
      "min": 0,
      "max": 100
    },
    "fecha": {
      "type": "date",
      "required": true
    },
    "ejercicio_nombre": {
      "type": "string"
    },
    "metricas_json": {
      "type": "json"
    },
    "resumen": {
      "type": "string",
      "required": true
    }
  }
}
