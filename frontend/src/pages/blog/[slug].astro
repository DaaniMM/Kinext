---
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const res = await fetch('https://kinext.es/api/articulos?populate=*&pagination[limit]=100');
  const data = await res.json();
  const articulos = data?.data || [];

  return articulos.map((articulo: any) => ({
    params: { slug: articulo.slug },
    props: { articulo },
  }));
}

const { articulo } = Astro.props;

// Artículos relacionados (misma categoría, excluyendo el actual)
const resRelacionados = await fetch(`https://kinext.es/api/articulos?populate=*&pagination[limit]=3`);
const dataRelacionados = await resRelacionados.json();
const relacionados = (dataRelacionados?.data || [])
  .filter((a: any) => a.slug !== articulo.slug)
  .slice(0, 3);

// Convertir markdown a HTML
function markdownToHtml(texto: string): string {
  if (!texto) return '';
  return texto
    .replace(/^## (.*$)/gm, '</p><h2 class="text-2xl font-bold mt-12 mb-4 text-white border-l-4 border-[var(--color-primary)] pl-4">$1</h2><p class="text-gray-300 leading-relaxed mb-4">')
    .replace(/^### (.*$)/gm, '</p><h3 class="text-lg font-bold mt-6 mb-2 text-white">$1</h3><p class="text-gray-300 leading-relaxed mb-4">')
    .replace(/\*\*(.*?):\*\*/g, '</p><p class="text-sm font-bold text-[var(--color-primary)] uppercase tracking-wide mt-4 mb-1">$1</p><p class="text-gray-300 leading-relaxed mb-4">')
    .replace(/\*\*(.*?)\*\*/g, '<strong class="text-white font-semibold">$1</strong>')
    .replace(/^\* (.*$)/gm, '</p><li class="flex gap-2 mb-2 text-gray-300"><span class="text-[var(--color-primary)] mt-1 flex-shrink-0">→</span><span>$1</span></li><p class="text-gray-300 leading-relaxed mb-4">')
    .replace(/^---$/gm, '</p><hr class="border-white/10 my-10"><p class="text-gray-300 leading-relaxed mb-4">')
    .replace(/\n\n/g, '</p><p class="text-gray-300 leading-relaxed mb-6">')
    .replace(/\n/g, '<br>');
}

const contenidoHtml = markdownToHtml(articulo.contenido || '');
const fechaFormateada = new Date(articulo.publishedAt).toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' });
---

<Layout title={`${articulo.titulo} - KINEXT Blog`}>

  <!-- HERO ARTÍCULO -->
  <section class="pt-24 pb-12 px-6 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-[var(--color-primary)]/5 to-transparent pointer-events-none"></div>
    <div class="max-w-4xl mx-auto relative z-10">

      <!-- Breadcrumb -->
      <div class="flex items-center gap-2 text-sm text-gray-500 mb-8">
        <a href="/" class="hover:text-white transition">Inicio</a>
        <span>/</span>
        <a href="/blog" class="hover:text-white transition">Blog</a>
        <span>/</span>
        <span class="text-gray-400 truncate max-w-xs">{articulo.titulo}</span>
      </div>

      <!-- Categorías -->
      <div class="flex flex-wrap gap-2 mb-6">
        {(articulo.categoria || []).map((cat: string) => (
          <span class="px-3 py-1 rounded-full text-xs font-semibold bg-[var(--color-primary)]/20 text-[var(--color-primary)] border border-[var(--color-primary)]/30">
            {cat}
          </span>
        ))}
      </div>

      <!-- Título -->
      <h1 class="text-4xl md:text-5xl font-black leading-tight mb-6">
        {articulo.titulo}
      </h1>

      <!-- Extracto -->
      <p class="text-xl text-gray-400 leading-relaxed mb-8">
        {articulo.extracto}
      </p>

      <!-- Metadata -->
      <div class="flex items-center gap-4 text-sm text-gray-500 pb-8 border-b border-white/10">
        <div class="flex items-center gap-2">
          <div class="w-8 h-8 rounded-full bg-gradient-to-br from-[var(--color-primary)] to-[var(--color-secondary)] flex items-center justify-center text-xs font-bold">
            {articulo.autor?.charAt(0) || 'K'}
          </div>
          <span class="text-gray-300">{articulo.autor}</span>
        </div>
        <span>·</span>
        <span>{fechaFormateada}</span>
      </div>
    </div>
  </section>

  <!-- IMAGEN PORTADA -->
  {articulo.imagen_portada?.url && (
    <section class="px-6 mb-12">
      <div class="max-w-4xl mx-auto">
        <img
          src={`https://kinext.es${articulo.imagen_portada.url}`}
          alt={articulo.titulo}
          class="w-full rounded-2xl object-cover max-h-[500px]"
        />
      </div>
    </section>
  )}

  <!-- CONTENIDO -->
  <section class="px-6 pb-24 mb-16">
    <div class="max-w-3xl mx-auto">
      <div class="prose-kinext text-gray-300 leading-relaxed">
        <p class="text-gray-300 leading-relaxed mb-4" set:html={contenidoHtml} />
      </div>
    </div>
  </section>

  <!-- ARTÍCULOS RELACIONADOS -->
  {relacionados.length > 0 && (
    <section class="py-24 px-6 bg-white/5">
      <div class="max-w-7xl mx-auto px-6">
        <h2 class="text-3xl font-bold mb-10 text-center">
          Artículos <span class="gradient-text">relacionados</span>
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {relacionados.map((rel: any) => (
            <article class="glass-surface rounded-2xl overflow-hidden hover:scale-[1.02] transition-all group">
              {rel.imagen_portada?.url && (
                <div class="h-44 overflow-hidden">
                  <img
                    src={`https://kinext.es${rel.imagen_portada.url}`}
                    alt={rel.titulo}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  />
                </div>
              )}
              <div class="p-6">
                <div class="flex flex-wrap gap-1 mb-3">
                  {(rel.categoria || []).map((cat: string) => (
                    <span class="px-2 py-0.5 rounded-full text-xs bg-white/10 text-gray-400">{cat}</span>
                  ))}
                </div>
                <h3 class="font-bold mb-2 leading-snug group-hover:text-[var(--color-primary)] transition-colors line-clamp-2">
                  {rel.titulo}
                </h3>
                <a href={`/blog/${rel.slug}`} class="text-sm font-semibold gradient-text">
                  Leer →
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>

      <div class="flex justify-center mt-12">
        <a href="/blog" class="px-10 py-4 rounded-lg glass-surface font-semibold text-lg relative overflow-hidden transition-all duration-150 group">
          <span class="absolute inset-0 bg-gradient-to-r from-[var(--color-primary)] to-[var(--color-secondary)] opacity-0 group-hover:opacity-100 transition-opacity duration-500"></span>
          <span class="relative z-10">Ver todos los blogs</span>
        </a>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="py-24 px-6">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-4xl font-black mb-6">
        Aplica lo que <span class="gradient-text">aprendiste</span>
      </h2>
      <p class="text-xl text-gray-400 mb-10">
        Analiza tu técnica con IA y recibe feedback en tiempo real.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/analizar" class="px-10 py-4 rounded-lg bg-gradient-to-r from-[var(--color-primary)] to-[var(--color-secondary)] text-white font-bold text-lg hover:scale-105 transition-transform">
          Analizar mi técnica
        </a>
        
      </div>
    </div>
  </section>

</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
