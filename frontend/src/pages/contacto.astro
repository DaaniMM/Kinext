---
import Layout from '../layouts/Layout.astro';

const STRAPI = "http://13.62.216.127:1337";

let config = {};
let faqs = [];

try {
  const [configRes, faqsRes] = await Promise.all([
    fetch(`${STRAPI}/api/configuracion-sitio`),
    fetch(`${STRAPI}/api/faqs?filters[categoria][$eq]=contacto&sort=orden:asc&pagination[limit]=10`)
  ]);
  const configData = await configRes.json();
  const faqsData = await faqsRes.json();
  config = configData.data || {};
  faqs = faqsData.data || [];
} catch (e) {
  console.error("Error fetching contact data:", e);
}

const redes = [
  { nombre: "Instagram", url: config.instagram_url, icon: "fa-brands fa-instagram" },
  { nombre: "Facebook", url: config.facebook_url, icon: "fa-brands fa-facebook" },
  { nombre: "LinkedIn", url: config.linkedin_url, icon: "fa-brands fa-linkedin" },
].filter(r => r.url);
---

<Layout title="KINEXT - Contacto">

  <!-- HERO -->
  <section class="min-h-screen flex items-center justify-center px-6 pt-24 pb-12 text-center relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-[var(--color-primary)]/5 to-transparent pointer-events-none"></div>
    <div class="max-w-3xl mx-auto relative z-10">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full glass-surface mb-6">
        <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
        <span class="text-xs text-gray-400">Respondemos en menos de 24h</span>
      </div>
      <h1 class="text-6xl md:text-7xl font-black tracking-tight mb-6">
        Habla con <span class="gradient-text">nosotros</span>
      </h1>
      <p class="text-xl text-gray-400 max-w-2xl mx-auto">
        ¿Tienes dudas, sugerencias o quieres colaborar? Estamos aquí.
      </p>
    </div>
  </section>

  <!-- FORM + INFO -->
  <section class="py-16 px-6 pb-32">
    <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-5 gap-12">

      <!-- FORMULARIO -->
      <div class="lg:col-span-3">
        <div class="glass-surface rounded-2xl p-8">
          <h2 class="text-2xl font-bold mb-8">Envíanos un mensaje</h2>

          <div id="mensajeExito" class="hidden mb-6 p-4 rounded-xl bg-green-500/10 border border-green-500/30 text-green-400 text-sm">
            <i class="fa-solid fa-circle-check mr-2"></i>Mensaje enviado correctamente. Te responderemos pronto.
          </div>
          <div id="mensajeError" class="hidden mb-6 p-4 rounded-xl bg-red-500/10 border border-red-500/30 text-red-400 text-sm">
            <i class="fa-solid fa-circle-xmark mr-2"></i>Error al enviar. Por favor inténtalo de nuevo.
          </div>

          <form id="formContacto" class="space-y-6">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-semibold text-gray-400 mb-2">Nombre *</label>
                <input type="text" id="nombre" required placeholder="Tu nombre" class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder-gray-600 focus:outline-none focus:border-[var(--color-primary)] transition"/>
              </div>
              <div>
                <label class="block text-sm font-semibold text-gray-400 mb-2">Email *</label>
                <input type="email" id="email" required placeholder="tu@email.com" class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder-gray-600 focus:outline-none focus:border-[var(--color-primary)] transition"/>
              </div>
            </div>

            <div>
              <label class="block text-sm font-semibold text-gray-400 mb-2">Asunto *</label>
              <select id="asunto" required class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white focus:outline-none focus:border-[var(--color-primary)] transition appearance-none cursor-pointer">
                <option value="" disabled selected>Selecciona un asunto</option>
                <option value="Consulta general">Consulta general</option>
                <option value="Soporte técnico">Soporte técnico</option>
                <option value="Análisis IA">Análisis IA</option>
                <option value="Soy entrenador">Soy entrenador y quiero unirme</option>
                <option value="Planes y facturación">Planes y facturación</option>
                <option value="Colaboración">Colaboración o partnership</option>
                <option value="Otro">Otro</option>
              </select>
            </div>

            <div>
              <label class="block text-sm font-semibold text-gray-400 mb-2">Mensaje *</label>
              <textarea id="mensaje" required rows="6" placeholder="Cuéntanos en qué podemos ayudarte..." class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder-gray-600 focus:outline-none focus:border-[var(--color-primary)] transition resize-none"></textarea>
            </div>

            <button type="submit" id="btnEnviar" class="w-full px-8 py-4 rounded-xl bg-gradient-to-r from-[var(--color-primary)] to-[var(--color-secondary)] text-white font-bold text-lg hover:scale-[1.02] transition-transform disabled:opacity-50 disabled:cursor-not-allowed">
              Enviar mensaje
            </button>
          </form>
        </div>
      </div>

      <!-- INFO LATERAL -->
      <div class="lg:col-span-2 flex flex-col gap-4 h-full">

        <!-- Email + Teléfono + Ubicación -->
        <div class="glass-surface rounded-2xl p-6 flex-1">
          <h3 class="font-bold text-lg mb-5">Contacto directo</h3>
          <div class="space-y-5">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl bg-[var(--color-primary)]/20 flex items-center justify-center flex-shrink-0">
                <i class="fa-solid fa-envelope text-[var(--color-primary)]"></i>
              </div>
              <div>
                <p class="text-xs text-gray-500 mb-0.5 uppercase tracking-wider">Email</p>
                <a href={`mailto:${config.email_contacto || 'kinext@email.com'}`} class="text-[var(--color-primary)] font-semibold hover:underline text-sm">
                  {config.email_contacto || 'kinext@email.com'}
                </a>
              </div>
            </div>
            <div class="w-full h-px bg-white/5"></div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl bg-[var(--color-secondary)]/20 flex items-center justify-center flex-shrink-0">
                <i class="fa-solid fa-phone text-[var(--color-secondary)]"></i>
              </div>
              <div>
                <p class="text-xs text-gray-500 mb-0.5 uppercase tracking-wider">Teléfono · Lun–Vie 9–18h</p>
                <a href={`tel:${config.telefono_contacto || '+34600123456'}`} class="text-[var(--color-primary)] font-semibold hover:underline text-sm">
                  {config.telefono_contacto || '+34 600 123 456'}
                </a>
              </div>
            </div>
            <div class="w-full h-px bg-white/5"></div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl bg-green-500/20 flex items-center justify-center flex-shrink-0">
                <i class="fa-solid fa-location-dot text-green-400"></i>
              </div>
              <div>
                <p class="text-xs text-gray-500 mb-0.5 uppercase tracking-wider">Ubicación</p>
                <p class="text-white text-sm">{config.direccion || 'Málaga, Andalucía, España'}</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Redes + tiempo respuesta -->
        <div class="glass-surface rounded-2xl p-6 flex-1 flex flex-col gap-4">
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
            <p class="text-sm text-gray-400">Respondemos en <span class="text-white font-semibold">menos de 24h</span></p>
          </div>
          {redes.length > 0 && (
            <div class="flex flex-col gap-3">
              {redes.map(r => (
                <a href={r.url} target="_blank" class="flex items-center gap-4 p-4 rounded-xl bg-white/5 hover:bg-white/10 text-gray-300 hover:text-[var(--color-primary)] transition-all group">
                  <i class={`${r.icon} text-xl w-6 text-center`}></i>
                  <span class="font-semibold text-base">{r.nombre}</span>
                  <i class="fa-solid fa-arrow-right ml-auto text-gray-600 group-hover:text-[var(--color-primary)] transition-colors"></i>
                </a>
              ))}
            </div>
          )}
        </div>

      </div>
    </div>

    <!-- FAQs -->
    {faqs.length > 0 && (
      <div class="max-w-3xl mx-auto mt-20">
        <h2 class="text-3xl font-black text-center mb-10">Preguntas <span class="gradient-text">frecuentes</span></h2>
        <div class="space-y-4">
          {faqs.map((faq) => (
            <div class="glass-surface rounded-2xl overflow-hidden">
              <button class="faq-btn w-full flex items-center justify-between px-6 py-5 text-left">
                <span class="font-semibold text-white">{faq.pregunta}</span>
                <i class="faq-icon fa-solid fa-plus text-[var(--color-primary)] ml-4 flex-shrink-0 transition-transform duration-300"></i>
              </button>
              <div class="faq-content hidden px-6 pb-5">
                <p class="text-gray-400 text-sm leading-relaxed">{faq.respuesta}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

  </section>

</Layout>

<script>
  // FAQ accordion
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const content = btn.nextElementSibling as HTMLElement;
      const icon = btn.querySelector('.faq-icon') as HTMLElement;
      const isOpen = !content.classList.contains('hidden');
      document.querySelectorAll('.faq-content').forEach(c => c.classList.add('hidden'));
      document.querySelectorAll('.faq-icon').forEach(i => {
        (i as HTMLElement).classList.remove('fa-minus');
        (i as HTMLElement).classList.add('fa-plus');
      });
      if (!isOpen) {
        content.classList.remove('hidden');
        icon.classList.remove('fa-plus');
        icon.classList.add('fa-minus');
      }
    });
  });

  // Form
  const form = document.getElementById('formContacto') as HTMLFormElement;
  const btnEnviar = document.getElementById('btnEnviar') as HTMLButtonElement;
  const mensajeExito = document.getElementById('mensajeExito');
  const mensajeError = document.getElementById('mensajeError');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const nombre = (document.getElementById('nombre') as HTMLInputElement).value;
    const email = (document.getElementById('email') as HTMLInputElement).value;
    const asunto = (document.getElementById('asunto') as HTMLSelectElement).value;
    const mensaje = (document.getElementById('mensaje') as HTMLTextAreaElement).value;

    btnEnviar.disabled = true;
    btnEnviar.textContent = 'Enviando...';
    mensajeExito?.classList.add('hidden');
    mensajeError?.classList.add('hidden');

    try {
      const res = await fetch('http://13.62.216.127:8000/contacto', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ nombre, email, asunto, mensaje })
      });
      if (res.ok) {
        mensajeExito?.classList.remove('hidden');
        form.reset();
      } else {
        mensajeError?.classList.remove('hidden');
      }
    } catch {
      mensajeError?.classList.remove('hidden');
    } finally {
      btnEnviar.disabled = false;
      btnEnviar.textContent = 'Enviar mensaje';
    }
  });
</script>