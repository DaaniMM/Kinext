---
import Layout from '../layouts/Layout.astro';

// Fetch Trainers desde Strapi
const resTrainers = await fetch('https://kinext.es/api/entrenadores?populate=*');
const dataTrainers = await resTrainers.json();
const trainers = dataTrainers.data || [];
console.log('TRAINER 1:', JSON.stringify(trainers[0], null, 2));
---

<Layout title="KINEXT - Marketplace">

  <section class="min-h-screen flex flex-col items-center justify-center px-6 pt-20 pb-8">
    <div class="max-w-4xl mx-auto text-center mb-16">
      <h1 class="text-6xl md:text-8xl font-black tracking-tight mb-6" style="font-family: 'Orbitron', sans-serif;">
        Encuentra tu <span class="gradient-text">Entrenador</span>
      </h1>
      <p class="text-xl text-gray-400 max-w-2xl mx-auto">
        247 profesionales verificados listos para ayudarte a alcanzar tus objetivos
      </p>
    </div>

    <div class="w-full max-w-4xl mx-auto">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center py-10 px-6">
        <div>
          <div class="text-3xl font-bold stat gradient-text">247</div>
          <div class="text-sm text-gray-500 mt-1">Entrenadores</div>
        </div>
        <div>
          <div class="text-3xl font-bold stat gradient-text">32</div>
          <div class="text-sm text-gray-500 mt-1">Ciudades</div>
        </div>
        <div>
          <div class="text-3xl font-bold stat text-white">1.8K</div>
          <div class="text-sm text-gray-500 mt-1">Sesiones</div>
        </div>
        <div>
          <div class="text-3xl font-bold stat text-white">4.8★</div>
          <div class="text-sm text-gray-500 mt-1">Rating medio</div>
        </div>
      </div>
    </div>
  </section>

  <!-- FILTROS + BUSCADOR -->
  <section class="py-12 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="glass-surface rounded-2xl p-6 mb-8">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
          <input type="text" id="searchInput" placeholder="Buscar por nombre..." class="px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-white placeholder-gray-500 focus:outline-none focus:border-[var(--color-primary)]"/>
          <select id="cityFilter" class="px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-white focus:outline-none focus:border-[var(--color-primary)]">
            <option value="">Todas las ciudades</option>
            <option value="Madrid">Madrid</option>
            <option value="Barcelona">Barcelona</option>
            <option value="Valencia">Valencia</option>
            <option value="Sevilla">Sevilla</option>
            <option value="Málaga">Málaga</option>
          </select>
          <select id="specialtyFilter" class="px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-white focus:outline-none focus:border-[var(--color-primary)]">
            <option value="">Todas las especialidades</option>
            <option value="Hipertrofia">Hipertrofia</option>
            <option value="Fuerza">Fuerza</option>
            <option value="CrossFit">CrossFit</option>
            <option value="Powerlifting">Powerlifting</option>
            <option value="Calistenia">Calistenia</option>
          </select>
          <select id="sortFilter" class="px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-white focus:outline-none focus:border-[var(--color-primary)]">
            <option value="rating">Rating ↓</option>
            <option value="price-asc">Precio ↑</option>
            <option value="price-desc">Precio ↓</option>
          </select>
        </div>
        <div class="mt-4 text-sm text-gray-400">
          Mostrando <span id="resultCount">{trainers.length}</span> de {trainers.length} entrenadores
        </div>
      </div>

      <!-- GRID TRAINERS -->
      <div id="trainersGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-8"></div>

      <!-- LOAD MORE -->
      <div class="text-center mt-12">
        <button id="loadMoreBtn" class="px-8 py-4 rounded-lg glass-surface font-semibold hover:bg-white/10 transition">
          Cargar más entrenadores
        </button>
      </div>

    </div>
  </section>

  <!-- CTA CONTACTO -->
  <section class="py-24 px-6 bg-white/5">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">¿No encuentras lo que buscas?</h2>
      <p class="text-gray-400 mb-8">Contáctanos y te ayudamos a encontrar el entrenador perfecto para tus objetivos</p>
      <a href="/contacto" class="inline-block px-8 py-4 rounded-lg bg-gradient-to-r from-[var(--color-primary)] to-[var(--color-secondary)] text-white font-bold hover:scale-105 transition-transform">
        Contactar
      </a>
    </div>
  </section>

  <!-- MODAL TRAINER -->
  <div id="trainerModal" class="fixed inset-0 z-50 hidden overflow-y-auto" style="background: rgba(0,0,0,0.92); backdrop-filter: blur(8px);">
    <div class="min-h-full flex items-center justify-center p-6">
      <div class="rounded-2xl max-w-2xl w-full relative max-h-[80vh] overflow-y-auto" style="background: #111111; border: 1px solid rgba(255,255,255,0.12);">
        <button id="closeModal" class="absolute top-4 right-4 w-9 h-9 flex items-center justify-center rounded-full bg-white/10 text-white text-xl hover:bg-white/20 transition font-bold z-10">
          ×
        </button>
        <div id="modalContent"></div>
      </div>
    </div>
  </div>

</Layout>

<script define:vars={{ trainers }}>
  const modal = document.getElementById('trainerModal');
  const closeModalBtn = document.getElementById('closeModal');
  const modalContent = document.getElementById('modalContent');

  function calcularMedia(resenas) {
    if (!resenas || resenas.length === 0) return '—';
    const suma = resenas.reduce((acc, r) => acc + r.puntuacion, 0);
    return (suma / resenas.length).toFixed(2);
  }

  function renderCard(trainer) {
    return `
      <div class="tilt-card trainer-card glass-surface rounded-xl overflow-hidden border border-white/10 cursor-pointer hover:border-[var(--color-primary)]/30 transition-all" data-trainer-id="${trainer.id}">
        <div class="flex gap-4 p-4 relative">
          <div style="height: 200px;" class="rounded-lg bg-gray-900 flex-shrink-0 overflow-hidden relative">
            ${trainer.foto_perfil?.url ? `<img src="https://kinext.es${trainer.foto_perfil.url}" alt="${trainer.nombre}" class="w-full h-full object-cover" />` : ''}
          </div>
          <div class="absolute bottom-2 right-2">
            <span class="px-2 py-1 rounded bg-black/60 backdrop-blur-sm text-xs font-bold">★ ${calcularMedia(trainer.resenas)}</span>
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex items-start justify-between mb-2">
              <div class="flex-1 min-w-0">
                <h3 class="text-lg font-bold truncate">${trainer.nombre}</h3>
                <p class="text-xs text-gray-400">${trainer.ciudad}</p>
              </div>
              <div class="text-right ml-2">
                <div class="text-xl font-bold gradient-text whitespace-nowrap">${trainer.precio_sesion}€</div>
                <div class="text-xs text-gray-500">/sesión</div>
              </div>
            </div>
            <div class="flex gap-1 mb-2 flex-wrap">
              ${trainer.modalidad?.slice(0, 2).map(mod => `<span class="px-2 py-0.5 rounded-full bg-orange-500/10 border border-orange-500/30 text-orange-400 text-xs">${mod}</span>`).join('')}
            </div>
            <div class="flex gap-1 mb-2 flex-wrap">
              ${trainer.especialidad?.slice(0, 2).map(esp => `<span class="px-2 py-0.5 rounded-full bg-purple-500/10 border border-purple-500/30 text-purple-400 text-xs">${esp}</span>`).join('')}
            </div>
            <p class="text-xs text-gray-400 line-clamp-2 leading-relaxed">${trainer.bio}</p>
          </div>
        </div>
      </div>
    `;
  }

  function attachCardEvents() {
    document.querySelectorAll('.trainer-card').forEach(card => {
      card.addEventListener('click', () => {
        const trainerId = parseInt(card.dataset.trainerId);
        const trainer = trainers.find(t => t.id === trainerId);
        if (trainer) openModal(trainer);
      });
    });
  }

  function openModal(trainer) {
    document.body.style.overflow = 'hidden';
    modalContent.innerHTML = `
      <div class="p-6">
        <div class="flex gap-6 mb-6 mt-2">
          <img src="https://kinext.es${trainer.foto_perfil.url}" alt="${trainer.nombre}" class="w-40 h-48 rounded-lg object-cover flex-shrink-0" />
          <div class="flex-1">
            <h2 class="text-3xl font-bold mb-2">${trainer.nombre}</h2>
            <p class="text-gray-400 mb-4">${trainer.ciudad} • ${trainer.experiencia_anos} años exp.</p>
            <div class="flex gap-2 mb-4 flex-wrap">
              ${trainer.modalidad.map(m => `<span class="px-3 py-1 rounded-full bg-orange-500/10 border border-orange-500/30 text-orange-400 text-sm">${m}</span>`).join('')}
            </div>
            <div class="text-4xl font-bold gradient-text mb-2">${trainer.precio_sesion}€ <span class="text-sm text-gray-500">/sesión</span></div>
            <div class="text-yellow-400 text-lg">★ ${calcularMedia(trainer.resenas)} (${trainer.resenas?.length || 0} reseñas)</div>
          </div>
        </div>
        <div class="mb-6">
          <h3 class="text-xl font-bold mb-2">Sobre mí</h3>
          <p class="text-gray-300 leading-relaxed">${trainer.bio}</p>
        </div>
        <div class="mb-6">
          <h3 class="text-xl font-bold mb-2">Certificaciones</h3>
          <p class="text-gray-300 whitespace-pre-line">${trainer.certificaciones}</p>
        </div>
        <div class="mb-6">
          <h3 class="text-xl font-bold mb-2">Idiomas</h3>
          <p class="text-gray-300">${trainer.idiomas.join(', ')}</p>
        </div>
        <div class="mb-6">
          <h3 class="text-xl font-bold mb-4">Reseñas</h3>
          ${trainer.resenas.slice(0, 3).map(r => `
            <div class="glass-surface rounded-lg px-5 py-4 mb-3">
              <div class="flex items-center justify-between mb-2">
                <span class="font-semibold">${r.autor}</span>
                <span class="text-yellow-400">${'★'.repeat(r.puntuacion)}</span>
              </div>
              <p class="text-sm text-gray-300 pb-1">${r.texto}</p>
            </div>
          `).join('')}
        </div>
        <a href="mailto:${trainer.email}" class="block text-center mt-2 px-8 py-4 rounded-lg bg-gradient-to-r from-[var(--color-primary)] to-[var(--color-secondary)] text-white font-bold hover:scale-105 transition-transform">
          Contactar Ahora
        </a>
      </div>
    `;
    modal.classList.remove('hidden');
    modal.classList.add('block');
    modal.scrollTop = 0;
  }

  function closeModal() {
    document.body.style.overflow = '';
    modal.classList.add('hidden');
    modal.classList.remove('block');
  }

  closeModalBtn.addEventListener('click', closeModal);
  modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

  const searchInput = document.getElementById('searchInput');
  const cityFilter = document.getElementById('cityFilter');
  const specialtyFilter = document.getElementById('specialtyFilter');
  const sortFilter = document.getElementById('sortFilter');
  const trainersGrid = document.getElementById('trainersGrid');
  const resultCount = document.getElementById('resultCount');
  const loadMoreBtn = document.getElementById('loadMoreBtn');

  const POR_PAGINA = 4;
  let filteredGlobal = [];

  function filterAndRender() {
    const searchVal = searchInput.value.toLowerCase();
    const cityVal = cityFilter.value;
    const specialtyVal = specialtyFilter.value;
    const sortVal = sortFilter.value;

    filteredGlobal = trainers.filter(t => {
      const searchRegex = new RegExp(searchVal, "i");
      const matchName = searchRegex.test(t.nombre);
      const matchCity = cityVal === '' || t.ciudad === cityVal;
      const matchSpecialty = specialtyVal === '' || (t.especialidad && t.especialidad.includes(specialtyVal));
      return matchName && matchCity && matchSpecialty;
    });

    if (sortVal === 'price-asc') filteredGlobal.sort((a, b) => a.precio_sesion - b.precio_sesion);
    if (sortVal === 'price-desc') filteredGlobal.sort((a, b) => b.precio_sesion - a.precio_sesion);
    if (sortVal === 'rating') filteredGlobal.sort((a, b) => {
      const mediaA = a.resenas?.length ? a.resenas.reduce((s, r) => s + r.puntuacion, 0) / a.resenas.length : 0;
      const mediaB = b.resenas?.length ? b.resenas.reduce((s, r) => s + r.puntuacion, 0) / b.resenas.length : 0;
      return mediaB - mediaA;
    });

    resultCount.textContent = filteredGlobal.length;
    trainersGrid.innerHTML = filteredGlobal.slice(0, POR_PAGINA).map(renderCard).join('');
    attachCardEvents();

    if (filteredGlobal.length > POR_PAGINA) {
      loadMoreBtn.classList.remove('hidden');
    } else {
      loadMoreBtn.classList.add('hidden');
    }
  }

  loadMoreBtn.addEventListener('click', () => {
    trainersGrid.innerHTML = filteredGlobal.map(renderCard).join('');
    attachCardEvents();
    loadMoreBtn.classList.add('hidden');
  });

  searchInput.addEventListener('input', filterAndRender);
  cityFilter.addEventListener('change', filterAndRender);
  specialtyFilter.addEventListener('change', filterAndRender);
  sortFilter.addEventListener('change', filterAndRender);
  filterAndRender();
</script>