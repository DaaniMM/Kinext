//ANIMACIONES CON GSAP

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  
  gsap.registerPlugin(ScrollTrigger);

  // ==========================================
  // 1. HERO - ZOOM OUT DRAMÁTICO + GRADIENT ANIMADO
  // ==========================================
  const heroTimeline = gsap.timeline();
  
  heroTimeline
    .from('h1', {
      scale: 3,
      opacity: 0,
      duration: 1.2,
      ease: 'power3.out'
    })
    .from('.text-xl.text-gray-400', {
      y: 30,
      opacity: 0,
      duration: 0.8
    }, '-=0.4')
    .from('.hero-btn', {
      y: 20,
      opacity: 0,
      duration: 0.6,
      stagger: 0.1,
	  clearProps: "all"
    }, '-=0.3');

  // Gradiente animado "Entrenador"
  gsap.to('.gradient-text', {
  backgroundPosition: '300% center',
  duration: 10,
  repeat: -1,
  ease: 'none',
});

  // ==========================================
  // 2. STATS - CONTADOR ANIMADO
  // ==========================================
  function animateCounter(element, target) {
    gsap.to(element, {
      innerText: target,
      duration: 2,
      delay: 1.5,
      snap: { innerText: 1 },
      onUpdate: function() {
        if (target >= 1000) {
          element.textContent = (this.targets()[0].innerText / 1000).toFixed(1) + 'K';
        } else {
          element.textContent = Math.floor(this.targets()[0].innerText);
        }
      }
    });
  }

  const stats = document.querySelectorAll('.stat');
  animateCounter(stats[0], 247);
  animateCounter(stats[1], 32);
  animateCounter(stats[2], 1800);

    // ==========================================
  // 4. PLANES - PREMIUM POP
  // ==========================================
  gsap.from('.border-\\[var\\(--color-primary\\)\\]', {
    scrollTrigger: {
      trigger: '.border-\\[var\\(--color-primary\\)\\]',
      start: 'top 80%'
    },
    scale: 0.9,
    duration: 1,
    ease: 'back.out(5)'
  });
</script>