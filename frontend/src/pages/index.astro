---
import Layout from '../layouts/Layout.astro';

// Fetch Testimonios
const resTestimonios = await fetch('http://13.62.216.127:1337/api/testimonios?populate=*');
const { data: testimonios } = await resTestimonios.json();

// Fetch FAQs Generales
const resFaqs = await fetch('http://13.62.216.127:1337/api/faqs?filters[categoria][$eq]=general&populate=*');
const { data: faqs } = await resFaqs.json();

// Fetch Últimos 3 Blogs
const resBlogs = await fetch('http://13.62.216.127:1337/api/articulos?populate=*');
const dataBlogs = await resBlogs.json();
const blogs = dataBlogs.data || [];
---


<Layout title="KINEXT - Home">
  
  <!-- ========================================== -->
