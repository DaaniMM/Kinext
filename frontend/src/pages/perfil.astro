---
import Layout from '../layouts/Layout.astro';
---

<Layout title="KINEXT - Mi Perfil">

  <!-- Sin sesión: redirige a login (lo maneja el script) -->
  <div id="perfil-content" class="hidden">

    <section class="min-h-screen pt-32 pb-20 px-6">
      <div class="max-w-4xl mx-auto space-y-6">

        <!-- CABECERA PERFIL -->
        <div class="glass-surface rounded-2xl p-8">
          <div class="flex flex-col md:flex-row items-center md:items-start gap-6">

            <!-- Avatar -->
            <div class="relative flex-shrink-0">
              <div id="avatar-container" class="w-24 h-24 rounded-2xl bg-[var(--color-primary)]/20 border border-white/10 flex items-center justify-center overflow-hidden">
                <i class="fa-solid fa-user text-[var(--color-primary)] text-4xl"></i>
              </div>
            </div>

            <!-- Info -->
            <div class="flex-1 text-center md:text-left">
              <div class="flex flex-col md:flex-row md:items-center gap-3 mb-2">
                <h1 id="perfil-nombre" class="text-3xl font-black text-white"></h1>
                <span id="perfil-plan-badge" class="inline-block px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider self-center"></span>
              </div>
              <p id="perfil-email" class="text-gray-400 mb-1"></p>
              <p id="perfil-fecha" class="text-xs text-gray-600"></p>
            </div>

            <!-- Acciones -->
            <div class="flex flex-col gap-2 flex-shrink-0">
              <a href="/entrenamiento" class="flex items-center gap-2 px-5 py-2.5 rounded-xl bg-[var(--color-primary)]/10 border border-[var(--color-primary)]/20 text-[var(--color-primary)] text-sm font-semibold hover:bg-[var(--color-primary)]/20 transition">
                <i class="fa-solid fa-dumbbell"></i> Entrenar
              </a>
              <button id="btn-logout-perfil" class="flex items-center gap-2 px-5 py-2.5 rounded-xl bg-white/5 border border-white/10 text-gray-400 text-sm font-semibold hover:text-red-400 hover:border-red-400/20 transition">
                <i class="fa-solid fa-right-from-bracket"></i> Cerrar sesión
              </button>
            </div>
          </div>
        </div>

        <!-- STATS RÁPIDAS -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="glass-surface rounded-2xl p-5 text-center">
            <i class="fa-solid fa-brain text-[var(--color-primary)] text-2xl mb-2"></i>
            <p id="stat-analisis" class="text-2xl font-black text-white">0</p>
            <p class="text-xs text-gray-500 mt-1">Análisis IA</p>
          </div>
          <div class="glass-surface rounded-2xl p-5 text-center">
            <i class="fa-solid fa-dumbbell text-[var(--color-secondary)] text-2xl mb-2"></i>
            <p id="stat-entrenos" class="text-2xl font-black text-white">0</p>
            <p class="text-xs text-gray-500 mt-1">Entrenamientos</p>
          </div>
          <div class="glass-surface rounded-2xl p-5 text-center">
            <i class="fa-solid fa-fire text-orange-400 text-2xl mb-2"></i>
            <p id="stat-series" class="text-2xl font-black text-white">0</p>
            <p class="text-xs text-gray-500 mt-1">Series totales</p>
          </div>
          <div class="glass-surface rounded-2xl p-5 text-center">
            <i class="fa-solid fa-clock text-green-400 text-2xl mb-2"></i>
            <p id="stat-tiempo" class="text-2xl font-black text-white">0 min</p>
            <p class="text-xs text-gray-500 mt-1">Tiempo entreno</p>
          </div>
        </div>

        <!-- ANÁLISIS RECIENTES (solo premium/pro) -->
        <div id="section-analisis" class="glass-surface rounded-2xl p-8">
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-bold text-white flex items-center gap-2">
              <i class="fa-solid fa-brain text-[var(--color-primary)]"></i> Análisis recientes
            </h2>
            <a href="/analizar" class="text-sm text-[var(--color-primary)] hover:underline">Nuevo análisis →</a>
          </div>
          <div id="analisis-lista" class="space-y-3">
            <p class="text-sm text-center py-8">No has realizado ningún análisis todavía.</p>
          </div>
        </div>

        <!-- ANÁLISIS BLOQUEADO (solo free) -->
        <div id="section-analisis-blocked" class="hidden glass-surface rounded-2xl p-8 border border-orange-500/20">
          <div class="flex items-center gap-3 mb-4">
            <i class="fa-solid fa-lock text-orange-400 text-xl"></i>
            <h2 class="text-xl font-bold text-white">Análisis IA</h2>
            <span class="px-2 py-0.5 rounded-full bg-orange-500/10 text-orange-400 text-xs font-bold">PREMIUM</span>
          </div>
          <p class="text-gray-400 text-sm mb-4">El análisis biomecánico con IA está disponible en los planes Premium y Pro.</p>
          <a href="/planes" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-gradient-to-r from-[var(--color-primary)] to-[var(--color-secondary)] text-white text-sm font-bold hover:scale-105 transition-transform">
            <i class="fa-solid fa-arrow-up"></i> Mejorar plan
          </a>
        </div>

        <!-- ENTRENAMIENTOS RECIENTES -->
        <div class="glass-surface rounded-2xl p-8">
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-bold text-white flex items-center gap-2">
              <i class="fa-solid fa-dumbbell text-[var(--color-secondary)]"></i> Entrenamientos recientes
            </h2>
            <a href="/entrenamiento" class="text-sm text-[var(--color-primary)] hover:underline">Registrar entreno →</a>
          </div>
          <div id="entrenos-lista" class="space-y-3">
            <p class="text-sm text-center py-8">No has registrado ningún entrenamiento todavía.</p>
          </div>
        </div>

      </div>
    </section>

  </div>

</Layout>

<script>
  const STRAPI = 'http://13.62.216.127:1337';

  // Verificar sesión
  const raw = localStorage.getItem('kinext_user');
  if (!raw) {
    window.location.href = '/login';
  } else {
    const user = JSON.parse(raw);
    document.getElementById('perfil-content')!.classList.remove('hidden');
    renderPerfil(user);
    loadData(user);
  }

  function renderPerfil(user: any) {
    document.getElementById('perfil-nombre')!.textContent = user.nombre;
    document.getElementById('perfil-email')!.textContent = user.email;

    // Avatar
    if (user.foto_perfil) {
      document.getElementById('avatar-container')!.innerHTML = `<img src="http://13.62.216.127:1337${user.foto_perfil}" class="w-full h-full object-cover" />`;
    }

    // Badge plan
    const badge = document.getElementById('perfil-plan-badge')!;
    const planColors: Record<string, string> = {
      free: 'bg-gray-500/20 text-gray-400',
      premium: 'bg-[var(--color-primary)]/20 text-[var(--color-primary)]',
      pro: 'bg-yellow-500/20 text-yellow-400'
    };
    badge.className = `inline-block px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider self-center ${planColors[user.plan] || planColors.free}`;
    badge.textContent = user.plan;

    // Sección análisis según plan
    if (user.plan === 'free') {
      document.getElementById('section-analisis')!.classList.add('hidden');
      document.getElementById('section-analisis-blocked')!.classList.remove('hidden');
    }
  }

  async function loadData(user: any) {
    try {
      // Cargar entrenos
      const entrenosRes = await fetch(`${STRAPI}/api/registro-entrenamientos?filters[usuario][documentId][$eq]=${user.documentId}&populate[entreno_series]=true&sort=createdAt:desc&pagination[limit]=5`);
      const entrenosData = await entrenosRes.json();
      const entrenos = entrenosData.data || [];

      // Stats entrenos
      document.getElementById('stat-entrenos')!.textContent = String(entrenos.length);
      const totalSeries = entrenos.reduce((acc: number, e: any) => acc + (e.entreno_series?.length || 0), 0);
      const totalTiempo = entrenos.reduce((acc: number, e: any) => acc + (e.duracion || 0), 0);
      document.getElementById('stat-series')!.textContent = String(totalSeries);
      document.getElementById('stat-tiempo')!.textContent = formatDuracion(totalTiempo);

      // Render entrenos
      if (entrenos.length > 0) {
        document.getElementById('entrenos-lista')!.innerHTML = entrenos.map((e: any) => {
          const fecha = new Date(e.createdAt).toLocaleDateString('es-ES', { day: '2-digit', month: 'short', year: 'numeric' });
          const series = e.entreno_series?.length || 0;
          return `
            <div class="flex items-center justify-between p-4 rounded-xl bg-white/5 hover:bg-white/10 transition">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl bg-[var(--color-secondary)]/20 flex items-center justify-center">
                  <i class="fa-solid fa-dumbbell text-[var(--color-secondary)] text-sm"></i>
                </div>
                <div>
                  <p class="text-white text-sm font-semibold">${fecha}</p>
                  <p class="text-xs ">${series} series · ${formatDuracion(e.duracion || 0)}</p>
                </div>
              </div>
              ${e.notas ? `<p class="text-xs max-w-32 truncate">${e.notas}</p>` : ''}
            </div>
          `;
        }).join('');
      }

      // Cargar análisis (solo premium/pro)
      if (user.plan !== 'free') {
        const analisisRes = await fetch(`${STRAPI}/api/analises?filters[usuario][documentId][$eq]=${user.documentId}&sort=createdAt:desc&pagination[limit]=5`);
        const analisisData = await analisisRes.json();
        const analisis = analisisData.data || [];

        document.getElementById('stat-analisis')!.textContent = String(analisis.length);

        if (analisis.length > 0) {
          document.getElementById('analisis-lista')!.innerHTML = analisis.map((a: any) => {
            const fecha = new Date(a.createdAt).toLocaleDateString('es-ES', { day: '2-digit', month: 'short', year: 'numeric' });
            return `
              <div class="flex items-center justify-between p-4 rounded-xl bg-white/5 hover:bg-white/10 transition">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-xl bg-[var(--color-primary)]/20 flex items-center justify-center">
                    <i class="fa-solid fa-brain text-[var(--color-primary)] text-sm"></i>
                  </div>
                  <div>
                    <p class="text-white text-sm font-semibold">${a.ejercicio || 'Análisis'}</p>
                    <p class="text-xs text-gray-500">${fecha}</p>
                  </div>
                </div>
                <span class="text-xs text-gray-500">${a.puntuacion ? `${a.puntuacion}/100` : ''}</span>
              </div>
            `;
          }).join('');
        }
      }

    } catch (e) {
      console.error('Error cargando datos:', e);
    }
  }

  function formatDuracion(min: number) {
    if (!min) return '0 min';
    if (min < 60) return `${min} min`;
    return `${Math.floor(min/60)}h ${min%60}min`;
  }

  // Logout
  document.getElementById('btn-logout-perfil')!.addEventListener('click', () => {
    localStorage.removeItem('kinext_user');
    window.location.href = '/';
  });
</script>