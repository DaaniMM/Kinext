---
import Layout from '../layouts/Layout.astro';

// Fetch FAQs Técnicos
const resFaqsTecnicos = await fetch('http://13.62.216.127:1337/api/faqs?filters[categoria][$eq]=tecnico&populate=*');
const dataFaqsTecnicos = await resFaqsTecnicos.json();
const faqsTecnicos = dataFaqsTecnicos?.data || [];
---

<Layout title="KINEXT - Análisis IA">

  <!-- HERO -->
  <section class="min-h-screen flex items-center justify-center px-6 pt-24 pb-12">
  <div class="max-w-4xl mx-auto text-center">
    <h1 class="text-6xl md:text-8xl font-black tracking-tight mb-6">
      Análisis <span class="gradient-text">IA + MediaPipe</span>
    </h1>
    <p class="text-xl text-gray-400 max-w-2xl mx-auto">
      Sube un vídeo de tu ejercicio y recibe feedback biomecánico instantáneo con detección de 33 puntos articulares
    </p>
  </div>
</section>

  <!-- MAIN CONTAINER -->
  <section class="py-12 px-6 relative">
    <div class="max-w-5xl mx-auto">

      <!-- OVERLAY FREE USER (oculto por defecto, se muestra si user es free) -->
        <div id="freeUserOverlay" class="hidden fixed inset-0 z-50 flex items-center justify-center p-6" style="background: rgba(0,0,0,0.92); backdrop-filter: blur(8px);">
        <div class="glass-surface rounded-3xl max-w-md w-full p-8 text-center border-2 border-orange-500/30">
          <div class="text-5xl mb-4"><i class="fa-solid fa-lock text-orange-400"></i></div>
          <h2 class="text-3xl font-bold mb-4">Función <span class="gradient-text">Premium</span></h2>
          <p class="text-gray-400 mb-6">
            El análisis biomecánico IA está disponible solo para usuarios Premium y Pro.
          </p>
          <div class="flex flex-col gap-3">
            <a href="/planes" class="block px-8 py-4 rounded-lg bg-gradient-to-r from-[var(--color-primary)] to-[var(--color-secondary)] text-white font-bold hover:scale-105 transition-transform">
              Ver Planes
            </a>
            <a href="/" class="block px-8 py-4 rounded-lg glass-surface font-semibold hover:bg-white/10 transition">
              Volver al Home
            </a>
          </div>
        </div>
      </div>

      <!-- UPLOAD SECTION -->
      <div id="uploadSection" class="glass-surface rounded-2xl p-8 mb-8">
        <h2 class="text-2xl font-bold mb-6">Subir Vídeo</h2>
        
        <div class="border-2 border-dashed border-white/20 rounded-xl p-12 text-center hover:border-orange-500/50 transition-colors cursor-pointer" id="dropZone">
          <input type="file" id="videoInput" accept="video/*" class="hidden" />
          
          <div id="uploadPrompt">
            <div class="text-5xl mb-4"><i class="fa-solid fa-video text-[var(--color-primary)]"></i></div>
            <p class="text-xl font-semibold mb-2">Arrastra tu vídeo aquí</p>
            <p class="text-gray-400 text-sm mb-4">o haz click para seleccionar</p>
            <p class="text-xs text-gray-500">MP4, MOV, AVI • Máx 50MB</p>
          </div>

          <div id="videoPreview" class="hidden">
            <video id="previewVideo" class="max-w-full max-h-64 mx-auto rounded-lg mb-4"></video>
            <p class="text-sm text-gray-400 mb-4">Vídeo cargado: <span id="fileName" class="text-white font-semibold"></span></p>
            <button id="removeVideo" class="text-sm text-red-400 hover:text-red-300">Eliminar vídeo</button>
          </div>
        </div>

        <div class="mt-8 grid grid-cols-1 md:grid-cols-3 gap-4">
          <div>
            <label class="block text-sm font-semibold mb-2">Ejercicio</label>
            <select id="ejercicioSelect" class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-white focus:outline-none focus:border-[var(--color-primary)]">
              <option value="sentadilla">Sentadilla</option>
              <option value="peso_muerto">Peso Muerto</option>
              <option value="press_banca">Press Banca</option>
            </select>
          </div>
          
          <div>
            <label class="block text-sm font-semibold mb-2">Ángulo</label>
            <select id="anguloSelect" class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-white focus:outline-none focus:border-[var(--color-primary)]">
              <option value="lateral">Lateral</option>
              <option value="frontal">Frontal</option>
              <option value="posterior">Posterior</option>
            </select>
          </div>

          <div>
            <label class="block text-sm font-semibold mb-2">Peso (kg)</label>
            <input type="number" id="pesoInput" placeholder="Opcional" class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-white placeholder-gray-500 focus:outline-none focus:border-[var(--color-primary)]" />
          </div>
        </div>

        <!-- SLIDER TRAMO -->
        <div id="sliderContainer" class="hidden mt-6">
          <label class="block text-sm font-semibold mb-4">Seleccionar tramo del ejercicio <span class="text-gray-400 font-normal">(máx. 10 segundos)</span></label>
          <div id="timeSlider" class="mb-4"></div>
          <div class="flex justify-between text-sm text-gray-400 mt-2">
            <span>Inicio: <span id="startTimeLabel" class="text-white font-semibold">0.0s</span></span>
            <span class="text-yellow-400" id="duracionLabel">Duración: 10.0s</span>
            <span>Fin: <span id="endTimeLabel" class="text-white font-semibold">10.0s</span></span>
          </div>
        </div>

        <button id="analizarBtn" disabled class="w-full mt-8 px-8 py-4 rounded-lg bg-gradient-to-r from-[var(--color-primary)] to-[var(--color-secondary)] text-white font-bold disabled:opacity-50 disabled:cursor-not-allowed hover:scale-105 transition-transform">
          Analizar con IA
        </button>
      </div>

      <!-- LOADING STATE -->
      <div id="loadingSection" class="hidden glass-surface rounded-2xl p-12 text-center mb-8">
        <div class="inline-block w-16 h-16 border-4 border-white/20 border-t-orange-500 rounded-full animate-spin mb-6"></div>
        <h3 class="text-2xl font-bold mb-2">Analizando tu técnica...</h3>
        <p class="text-gray-400 mb-4">Esto puede tardar 10-30 segundos</p>
        <div class="max-w-md mx-auto">
          <div class="bg-white/10 rounded-full h-2 overflow-hidden">
            <div id="progressBar" class="bg-gradient-to-r from-orange-500 to-pink-500 h-full transition-all duration-300" style="width: 0%"></div>
          </div>
          <p id="loadingStep" class="text-sm text-gray-500 mt-2">Procesando vídeo...</p>
        </div>
      </div>

      <!-- RESULTADO SECTION -->
      <div id="resultadoSection" class="hidden">
        
        <!-- RESUMEN ANÁLISIS -->
        <div class="glass-surface rounded-2xl p-8 mb-8">
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-3xl font-bold">Resultado del Análisis</h2>
            <div id="scoreGlobal" class="px-6 py-3 rounded-lg bg-gradient-to-r from-green-500/20 to-green-600/20 border-2 border-green-500/50">
              <span class="text-sm text-gray-400">Puntuación</span>
              <div class="text-3xl font-black text-green-400">85/100</div>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="text-center p-6 rounded-xl bg-white/5">
              <div class="text-4xl mb-2"><i class="fa-solid fa-circle-check text-green-400"></i></div>
              <div class="text-2xl font-bold text-green-400" id="puntosCorrectos">12</div>
              <div class="text-sm text-gray-400">Puntos Correctos</div>
            </div>
            <div class="text-center p-6 rounded-xl bg-white/5">
              <div class="text-4xl mb-2"><i class="fa-solid fa-triangle-exclamation text-yellow-400"></i></div>
              <div class="text-2xl font-bold text-yellow-400" id="puntosAdvertencia">3</div>
              <div class="text-sm text-gray-400">Advertencias</div>
            </div>
            <div class="text-center p-6 rounded-xl bg-white/5">
              <div class="text-4xl mb-2"><i class="fa-solid fa-circle-xmark text-red-400"></i></div>
              <div class="text-2xl font-bold text-red-400" id="puntosError">1</div>
              <div class="text-sm text-gray-400">Errores Críticos</div>
            </div>
          </div>
        </div>

        <!-- ANÁLISIS -->
        <div class="glass-surface rounded-2xl p-8 mb-8">
          <h3 class="text-2xl font-bold mb-6">ANÁLISIS</h3>
          <div id="recomendacionesLista" class="space-y-3">
            <!-- Se llenará dinámicamente -->
          </div>
        </div>

        <!-- MEDIAPIPE SECTION -->
        <div id="seccionMediaPipe" class="hidden glass-surface rounded-2xl p-8 mb-8 border border-purple-500/20">
          <div class="flex items-center gap-3 mb-6">
            <i class="fa-solid fa-bone text-purple-400 text-xl"></i>
            <h3 class="text-2xl font-bold">Datos Biomecánicos <span class="text-purple-400">MediaPipe</span></h3>
            <span class="px-2 py-0.5 rounded-full bg-yellow-500/10 text-yellow-400 text-xs font-bold">PRO</span>
          </div>
          <div id="mpContenido"></div>
        </div>

        <!-- BOTONES ACCIÓN -->
        <div class="flex gap-4">
          <button id="nuevoAnalisisBtn" class="flex-1 px-8 py-4 rounded-lg glass-surface font-semibold hover:bg-white/10 transition">
            Nuevo Análisis
          </button>
          <button id="descargarBtn" class="flex-1 px-8 py-4 rounded-lg bg-gradient-to-r from-[var(--color-primary)] to-[var(--color-secondary)] text-white font-bold hover:scale-105 transition-transform">
            Descargar Informe PDF
          </button>
        </div>
      </div>

    </div>
  </section>

  <!-- FAQs TÉCNICOS -->
  <section class="py-24 px-6 bg-white/5">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold mb-4">
          Preguntas <span class="gradient-text">técnicas</span>
        </h2>
      </div>

      <div class="space-y-4">
        {faqsTecnicos.map(faq => (
          <details class="glass-surface rounded-xl p-6 group">
            <summary class="font-semibold cursor-pointer list-none flex justify-between items-center">
              {faq.pregunta}
              <span class="text-2xl group-open:rotate-45 transition-transform">+</span>
            </summary>
            <p class="text-gray-300 mt-4 leading-relaxed whitespace-pre-line">
              {faq.respuesta}
            </p>
          </details>
        ))}
      </div>
    </div>
  </section>

</Layout>

<script>
  import noUiSlider from 'nouislider';
  import 'nouislider/dist/nouislider.css';

  // ==========================================
  // SISTEMA AUTH (free no puede usar esta pagina)
  // ==========================================
  
  let userTier = 'free';
  try {
    const raw = localStorage.getItem('kinext_user');
    if (raw) {
      const user = JSON.parse(raw);
      userTier = user.plan || 'free';
    }
  } catch (e) {
    console.error('Error leyendo sesión:', e);
  };

  const freeOverlay = document.getElementById('freeUserOverlay');
  
  if (userTier === 'free') {
    freeOverlay.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  // ==========================================
  // UPLOAD VIDEO
  // ==========================================
  const dropZone = document.getElementById('dropZone');
  const videoInput = document.getElementById('videoInput');
  const uploadPrompt = document.getElementById('uploadPrompt');
  const videoPreview = document.getElementById('videoPreview');
  const previewVideo = document.getElementById('previewVideo');
  const fileName = document.getElementById('fileName');
  const removeVideo = document.getElementById('removeVideo');
  const analizarBtn = document.getElementById('analizarBtn');

  let selectedFile = null;

  dropZone.addEventListener('click', () => videoInput.click());

  videoInput.addEventListener('change', (e) => {
    const file = e.target.files[0];
    if (file) handleFile(file);
  });

  dropZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.classList.add('border-orange-500');
  });

  dropZone.addEventListener('dragleave', () => {
    dropZone.classList.remove('border-orange-500');
  });

  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('border-orange-500');
    const file = e.dataTransfer.files[0];
    if (file && file.type.startsWith('video/')) {
      handleFile(file);
    }
  });

  function handleFile(file) {
    selectedFile = file;
    fileName.textContent = file.name;
    
    const url = URL.createObjectURL(file);
    previewVideo.src = url;
    
    uploadPrompt.classList.add('hidden');
    videoPreview.classList.remove('hidden');
    analizarBtn.disabled = false;
  }

  // ==========================================
  // SLIDER TRAMO
  // ==========================================
  let startTime = 0;
  let endTime = 10;
  const sliderContainer = document.getElementById('sliderContainer');
  const timeSlider = document.getElementById('timeSlider');

  previewVideo.addEventListener('loadedmetadata', () => {
    const duration = previewVideo.duration;
    const maxEnd = Math.min(10, duration);

    sliderContainer.classList.remove('hidden');

    if (timeSlider.noUiSlider) {
      timeSlider.noUiSlider.destroy();
    }

    noUiSlider.create(timeSlider, {
      start: [0, maxEnd],
      connect: true,
      range: { min: 0, max: duration },
      step: 0.5,
      tooltips: false
    });

    timeSlider.noUiSlider.on('update', (values) => {
      startTime = parseFloat(values[0]);
      endTime = parseFloat(values[1]);

      if (endTime - startTime > 10) {
        endTime = startTime + 10;
        timeSlider.noUiSlider.set([startTime, endTime]);
      }

      document.getElementById('startTimeLabel').textContent = startTime.toFixed(1) + 's';
      document.getElementById('endTimeLabel').textContent = endTime.toFixed(1) + 's';
      document.getElementById('duracionLabel').textContent = 'Duración: ' + (endTime - startTime).toFixed(1) + 's';
        previewVideo.currentTime = startTime;
    });
  });

  removeVideo.addEventListener('click', (e) => {
    e.stopPropagation();
    selectedFile = null;
    videoInput.value = '';
    previewVideo.src = '';
    uploadPrompt.classList.remove('hidden');
    videoPreview.classList.add('hidden');
    analizarBtn.disabled = true;
    sliderContainer.classList.add('hidden');
  });

  // ==========================================
  // ANALIZAR
  // ==========================================
  const uploadSection = document.getElementById('uploadSection');
  const loadingSection = document.getElementById('loadingSection');
  const resultadoSection = document.getElementById('resultadoSection');
  const progressBar = document.getElementById('progressBar');
  const loadingStep = document.getElementById('loadingStep');

  analizarBtn.addEventListener('click', async () => {
  if (!selectedFile) return;

  const ejercicio = document.getElementById('ejercicioSelect').value;
  const formData = new FormData();
  formData.append('video', selectedFile);
  formData.append('ejercicio', ejercicio);
  formData.append('start_time', Math.floor(startTime));
  formData.append('end_time', Math.floor(endTime));
  formData.append('user_tier', userTier); // MEDIAPIPE -> envía el plan al backend
  const userId = JSON.parse(localStorage.getItem('kinext_user'))?.id || 0;
  formData.append('user_id', userId);
  uploadSection.classList.add('hidden');
  loadingSection.classList.remove('hidden');

  // Animación de progreso mientras espera
  let progress = 0;
  const steps = [
    { progress: 20, text: 'Procesando vídeo...' },
    { progress: 40, text: 'Detectando 33 puntos MediaPipe...' },
    { progress: 60, text: 'Analizando biomecánica...' },
    { progress: 80, text: 'Generando feedback con Gemini...' },
  ];
  let stepIndex = 0;
  const interval = setInterval(() => {
    if (stepIndex < steps.length) {
      progressBar.style.width = steps[stepIndex].progress + '%';
      loadingStep.textContent = steps[stepIndex].text;
      stepIndex++;
    }
  }, 4000);

  try {
    const response = await fetch('http://13.62.216.127:8000/analizar_video', {
      method: 'POST',
      body: formData
    });

    const data = await response.json();
console.log('RESPUESTA BACKEND:', JSON.stringify(data));
    clearInterval(interval);
    progressBar.style.width = '100%';
    loadingStep.textContent = 'Completado!';

    await new Promise(resolve => setTimeout(resolve, 500));

    loadingSection.classList.add('hidden');

    if (data.success) {
      mostrarResultado(data.msg);
      mostrarMediaPipe(data.metricas || null); // MEDIAPIPE -> muestra tarjetas si hay métricas
      resultadoSection.classList.remove('hidden');
      resultadoSection.scrollIntoView({ behavior: 'smooth' });
    } else {
      alert('Error del análisis: ' + data.msg);
      uploadSection.classList.remove('hidden');
    }

  } catch (error) {
    clearInterval(interval);
    loadingSection.classList.add('hidden');
    uploadSection.classList.remove('hidden');
    alert('Error de conexión con el servidor: ' + error.message);
  }
});

function markdownToHtml(texto) {
  return texto
    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*\*/g, '')
    .replace(/^\* /gm, '• ')
    .replace(/^---$/gm, '<hr class="border-white/10 my-4">')
    .replace(/\n/g, '<br>');
}

function mostrarResultado(texto) {
  const scoreMatch = texto.match(/Puntuaci[oó]n:\s*([\d.]+)\/10/i);
  const score = scoreMatch ? Math.round(parseFloat(scoreMatch[1]) * 10) : 0;

  document.getElementById('scoreGlobal').innerHTML = `
    <span class="text-sm text-gray-400">Puntuación</span>
    <div class="text-3xl font-black ${score >= 80 ? 'text-green-400' : score >= 50 ? 'text-yellow-400' : 'text-red-400'}">
      ${score}/100
    </div>
  `;

  const seccionBien = texto.match(/LO QUE HACES.*?(?=❌|🧠|🛠️|$)/s)?.[0] || '';
  const seccionErrores = texto.match(/❌.*?(?=🧠|🛠️|$)/s)?.[0] || '';
  const seccionCausas = texto.match(/🧠.*?(?=🛠️|$)/s)?.[0] || '';
  const seccionCorreccion = texto.match(/🛠️.*/s)?.[0] || '';

  document.getElementById('recomendacionesLista').innerHTML = `
    <div class="text-gray-300 leading-relaxed">${markdownToHtml(seccionBien + '\n\n' + seccionErrores + '\n\n' + seccionCausas + '\n\n' + seccionCorreccion)}</div>
  `;

  // Contar errores y advertencias reales del texto
  const numErrores = (texto.match(/❌/g) || []).length;
  const numAdvertencias = (texto.match(/⚠️/g) || []).length;
  const numBien = (texto.match(/✅/g) || []).length || 4;

  document.getElementById('puntosCorrectos').textContent = numBien;
  document.getElementById('puntosAdvertencia').textContent = numAdvertencias;
  document.getElementById('puntosError').textContent = numErrores;
}

  // ==========================================
  // MEDIAPIPE -> muestra tarjetas PRO o bloqueo Premium
  // ==========================================
  function mostrarMediaPipe(metricas) {
    const seccion = document.getElementById('seccionMediaPipe');
    seccion.classList.remove('hidden');

    if (userTier === 'pro' && metricas) {
      const rompe = metricas.rompe_paralelo ? '<span class="text-green-400">✓ Sí</span>' : '<span class="text-red-400">✗ No</span>';
      const valgo = metricas.valgo_detectado ? '<span class="text-red-400">⚠ Detectado</span>' : '<span class="text-green-400">✓ No detectado</span>';
      document.getElementById('mpContenido').innerHTML = `
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="text-center p-4 rounded-xl bg-white/5 border border-purple-500/20">
            <div class="text-xs text-gray-400 mb-1">Rodilla Izq. (mín)</div>
            <div class="text-2xl font-black text-purple-400">${metricas.angulo_rodilla_izq_min}°</div>
          </div>
          <div class="text-center p-4 rounded-xl bg-white/5 border border-purple-500/20">
            <div class="text-xs text-gray-400 mb-1">Rodilla Der. (mín)</div>
            <div class="text-2xl font-black text-purple-400">${metricas.angulo_rodilla_der_min}°</div>
          </div>
          <div class="text-center p-4 rounded-xl bg-white/5 border border-purple-500/20">
            <div class="text-xs text-gray-400 mb-1">Simetría</div>
            <div class="text-2xl font-black text-purple-400">${metricas.simetria_pct}%</div>
          </div>
          <div class="text-center p-4 rounded-xl bg-white/5 border border-purple-500/20">
            <div class="text-xs text-gray-400 mb-1">Profundidad</div>
            <div class="text-2xl font-black text-purple-400">${metricas.profundidad_media}°</div>
          </div>
          <div class="text-center p-4 rounded-xl bg-white/5 border border-purple-500/20">
            <div class="text-xs text-gray-400 mb-1">Rompe paralelo</div>
            <div class="text-lg font-bold mt-1">${rompe}</div>
          </div>
          <div class="text-center p-4 rounded-xl bg-white/5 border border-purple-500/20">
            <div class="text-xs text-gray-400 mb-1">Valgo rodilla</div>
            <div class="text-lg font-bold mt-1">${valgo}</div>
          </div>
          <div class="text-center p-4 rounded-xl bg-white/5 border border-purple-500/20">
            <div class="text-xs text-gray-400 mb-1">Tempo bajada</div>
            <div class="text-2xl font-black text-purple-400">${metricas.tempo_excentrico_seg}s</div>
          </div>
          <div class="text-center p-4 rounded-xl bg-white/5 border border-purple-500/20">
            <div class="text-xs text-gray-400 mb-1">Tempo subida</div>
            <div class="text-2xl font-black text-purple-400">${metricas.tempo_concentrico_seg}s</div>
          </div>
        </div>
        <p class="text-xs text-gray-500 mt-4 text-center">Basado en ${metricas.frames_analizados} frames analizados por MediaPipe</p>
      `;
    } else {
      document.getElementById('mpContenido').innerHTML = `
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6 opacity-40 pointer-events-none select-none blur-sm">
          ${['Rodilla Izq.','Rodilla Der.','Simetría','Profundidad','Paralelo','Valgo','Tempo ↓','Tempo ↑'].map(label => `
            <div class="text-center p-4 rounded-xl bg-white/5 border border-purple-500/20">
              <div class="text-xs text-gray-400 mb-1">${label}</div>
              <div class="text-2xl font-black text-purple-400">—</div>
            </div>
          `).join('')}
        </div>
        <div class="text-center">
          <i class="fa-solid fa-lock text-yellow-400 text-3xl mb-3"></i>
          <p class="text-white font-bold mb-1">Datos biomecánicos exactos</p>
          <p class="text-gray-400 text-sm mb-4">Ángulos reales, simetría y tempo calculados con MediaPipe. Disponible en <span class="text-yellow-400 font-bold">Plan PRO</span>.</p>
          <a href="/planes" class="inline-block px-6 py-3 rounded-lg bg-gradient-to-r from-[var(--color-primary)] to-[var(--color-secondary)] text-white font-bold hover:scale-105 transition-transform text-sm">
            Actualizar a PRO
          </a>
        </div>
      `;
    }
  }

  

  // ==========================================
  // NUEVO ANÁLISIS
  // ==========================================
  document.getElementById('nuevoAnalisisBtn').addEventListener('click', () => {
    resultadoSection.classList.add('hidden');
    uploadSection.classList.remove('hidden');
    removeVideo.click();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  document.getElementById('descargarBtn').addEventListener('click', () => {
    alert('Función de descarga PDF próximamente');
  });
</script>
